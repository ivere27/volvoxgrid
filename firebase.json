{
  "hosting": {
    "public": "dist/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/demos/web",
        "headers": [
          {
            "key": "Cross-Origin-Opener-Policy",
            "value": "same-origin"
          },
          {
            "key": "Cross-Origin-Embedder-Policy",
            "value": "require-corp"
          }
        ]
      },
      {
        "source": "/demos/web/**",
        "headers": [
          {
            "key": "Cross-Origin-Opener-Policy",
            "value": "same-origin"
          },
          {
            "key": "Cross-Origin-Embedder-Policy",
            "value": "require-corp"
          }
        ]
      },
      {
        "source": "**/*.wasm",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/wasm"
          }
        ]
      }
    ],
    "redirects": [
      {
        "source": "/",
        "destination": "/demos/web",
        "type": 302
      }
    ],
    "rewrites": [
      {
        "source": "/demos/web",
        "destination": "/demos/web/index.html"
      },
      {
        "source": "/demos/web/**",
        "destination": "/demos/web/index.html"
      },
      {
        "source": "/demos/excel",
        "destination": "/demos/excel/index.html"
      },
      {
        "source": "/demos/excel/**",
        "destination": "/demos/excel/index.html"
      },
      {
        "source": "/demos/excel-lite",
        "destination": "/demos/excel-lite/index.html"
      },
      {
        "source": "/demos/excel-lite/**",
        "destination": "/demos/excel-lite/index.html"
      }
    ]
  }
}
