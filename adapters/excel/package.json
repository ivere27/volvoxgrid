{
  "name": "@volvoxgrid/excel",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "description": "Excel/Sheets-like spreadsheet adapter for VolvoxGrid",
  "type": "module",
  "main": "dist/volvox-excel.umd.js",
  "module": "dist/volvox-excel.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/volvox-excel.js",
      "require": "./dist/volvox-excel.umd.js"
    },
    "./style.css": "./dist/excel.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "volvoxgrid": "^0.1.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "volvoxgrid": "file:../../web/js"
  },
  "dependencies": {
    "puppeteer": "^24.37.5"
  }
}
