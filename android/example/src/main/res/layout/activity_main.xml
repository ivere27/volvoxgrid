<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Row 1: Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:background="#D0D0D0">

        <Spinner
            android:id="@+id/spRendererMode"
            android:layout_width="104dp"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Debug"
            android:textSize="12sp" />

        <Switch
            android:id="@+id/swDebug"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="Cache"
            android:textSize="12sp" />

        <Spinner
            android:id="@+id/spTextCache"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp" />

        <Space
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/btnOverflowMenu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_more_vert"
            android:contentDescription="More actions"
            android:background="?attr/selectableItemBackgroundBorderless" />
    </LinearLayout>

    <!-- Row 2: Grid selector -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:background="#E3E3E3">

        <Button
            android:id="@+id/btnDemoSales"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Sales"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnDemoHierarchy"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="Hierarchy"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnDemoStress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="Stress"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- VolvoxGrid view fills remaining space -->
    <io.github.ivere27.volvoxgrid.VolvoxGridView
        android:id="@+id/gridView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Bottom status bar -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:textSize="12sp"
        android:background="#EFEFEF"
        android:text="Loading..." />

</LinearLayout>
